@page "/services/view/{id:int}"
@using ServicePlanner.Models
@using ServicePlanner.Services
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject ServiceService ServiceService
@inject SongService SongService
@inject IJSRuntime JS

<h3 class="mb-4">@(service?.Name ?? "Service")</h3>

@if (loading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (service != null)
{
    <div class="row mb-3">
        <div class="col-md-6">
            <strong>Service Date:</strong> @service.ServiceDate.ToString("MMM dd, yyyy")
        </div>
        <div class="col-md-6">
            <strong>Seasonal:</strong> @(service.IsSeasonal ? "Yes" : "No")
        </div>
    </div>

    @if (service.EventInstances != null && service.EventInstances.Any())
    {
        <div class="row mb-3">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                        <h6 class="mb-0">Service Events</h6>
                    </div>
                    <div class="card-body">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Event Type</th>
                                    <th>Person / Song</th>
                                    <th>Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var instance in service.EventInstances)
                                {
                                    <tr>
                                        <td>@instance.ServiceEvent?.Type</td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(instance.PersonName))
                                            {
                                                <div><i class="bi bi-person"></i> @instance.PersonName</div>
                                            }
                                            @if (instance.SongId.HasValue)
                                            {
                                                var song = songs?.FirstOrDefault(s => s.Id == instance.SongId);
                                                if (song != null)
                                                {
                                                    <div><i class="bi bi-music-note"></i> @song.SongName</div>
                                                }
                                            }
                                            @if (string.IsNullOrEmpty(instance.PersonName) && !instance.SongId.HasValue)
                                            {
                                                <span class="text-muted">Not assigned</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(instance.Notes))
                                            {
                                                <small class="text-muted">@instance.Notes</small>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <p class="mb-0">No events found for this service.</p>
        </div>
    }

    <div class="row mb-3">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Quick Stats</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <strong>Total Events:</strong>
                        <span class="badge bg-primary ms-2">@CurrentService.EventInstances.Count</span>
                    </div>

                    @{
                        var eventTypeCounts = CurrentService.EventInstances
                            .Where(e => e.ServiceEvent != null)
                            .GroupBy(e => e.ServiceEvent!.Type)
                            .Select(g => new { Type = g.Key, Count = g.Count() });

                        foreach (var count in eventTypeCounts)
                        {
                            <div>
                                <strong>@count.Type:</strong>
                                <span class="badge bg-secondary ms-2">@count.Count</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-primary" @onclick="CopyToClipboard">
            <i class="bi bi-clipboard"></i> Copy for Text
        </button>
        <AuthorizeView>
            <button type="button" class="btn btn-primary" @onclick="EditService">
                <i class="bi bi-pencil"></i> Edit Service
            </button>
        </AuthorizeView>
        <button type="button" class="btn btn-secondary" @onclick="BackToList">
            <i class="bi bi-arrow-left"></i> Back to Services
        </button>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Service? service;
    private List<Song>? songs;
    private bool loading = true;
    private Service CurrentService => service!;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        service = await ServiceService.GetServiceByIdAsync(Id);
        if (service == null)
        {
            Navigation.NavigateTo("/services");
            return;
        }
        loading = false;
    }

    private async Task LoadData()
    {
        songs = await SongService.GetAllSongsAsync();
    }

    private void EditService()
    {
        Navigation.NavigateTo($"/services/edit/{Id}");
    }

    private void BackToList()
    {
        Navigation.NavigateTo("/services");
    }

    private async Task CopyToClipboard()
    {
        if (service == null)
        {
            return;
        }

        var text = BuildShareText();
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private string BuildShareText()
    {
        if (service == null)
        {
            return string.Empty;
        }

        var songLookup = songs?.ToDictionary(
            s => s.Id,
            s => new SongInfo(s.SongName, s.Key)) ?? new Dictionary<int, SongInfo>();
        var builder = new System.Text.StringBuilder();

        builder.AppendLine(service.Name);
        builder.AppendLine($"Date: {service.ServiceDate:MMM dd, yyyy}");
        builder.AppendLine($"Seasonal: {(service.IsSeasonal ? "Yes" : "No")}");
        builder.AppendLine();
        builder.AppendLine("Events:");

        var index = 1;
        foreach (var instance in service.EventInstances)
        {
            var title = !string.IsNullOrWhiteSpace(instance.ServiceEvent?.Title)
                ? instance.ServiceEvent.Title
                : instance.ServiceEvent?.Type.ToString() ?? "Event";

            var details = new List<string>();
            if (!string.IsNullOrWhiteSpace(instance.PersonName))
            {
                details.Add($"Person: {instance.PersonName}");
            }

            if (instance.SongId.HasValue && songLookup.TryGetValue(instance.SongId.Value, out var songInfo))
            {
                var keySuffix = string.IsNullOrWhiteSpace(songInfo.Key) ? "" : $" (Key: {songInfo.Key})";
                details.Add($"Song: {songInfo.SongName}{keySuffix}");
            }

            if (!string.IsNullOrWhiteSpace(instance.Notes))
            {
                details.Add($"Notes: {instance.Notes}");
            }

            if (details.Count == 0)
            {
                details.Add("Not assigned");
            }

            var typeLabel = instance.ServiceEvent?.Type.ToString();
            var titleLine = string.IsNullOrWhiteSpace(typeLabel) ? title : $"{title} ({typeLabel})";
            builder.AppendLine($"{index}. {titleLine} - {string.Join("; ", details)}");
            index++;
        }

        builder.AppendLine();
        var link = Navigation.ToAbsoluteUri($"/services/view/{Id}");
        builder.AppendLine($"View Service: {link}");

        return builder.ToString();
    }

    private sealed record SongInfo(string SongName, string? Key);
}
