@page "/services/create"
@page "/services/edit/{Id:int}"
@using ServicePlanner.Models
@using ServicePlanner.Services
@inject NavigationManager Navigation
@inject ServiceService ServiceService
@inject ServiceTemplateService TemplateService
@inject SongService SongService

<h3 class="mb-4">@Title</h3>

@if (loading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (service != null)
{
    <form @onsubmit="SaveService">
        <div class="row mb-3">
            <div class="col-md-6">
                <label for="serviceName" class="form-label">Service Name</label>
                <input type="text" class="form-control" id="serviceName" @bind="service.Name" required />
            </div>
            <div class="col-md-6">
                <label for="serviceDate" class="form-label">Service Date</label>
                <input type="date" class="form-control" id="serviceDate" @bind="service.ServiceDate" required />
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label for="templateId" class="form-label">Template</label>
                <select class="form-select" id="templateId" @bind="service.TemplateId" required>
                    <option value="0">Select a template...</option>
                    @if (templates != null)
                    {
                        @foreach (var template in templates)
                        {
                            <option value="@template.Id">@template.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-6">
                <div class="form-check form-switch mt-4">
                    <input class="form-check-input" type="checkbox" id="isSeasonal" @bind="service.IsSeasonal">
                    <label class="form-check-label" for="isSeasonal">Seasonal Service</label>
                </div>
            </div>
        </div>

        @if (service.EventInstances != null && service.EventInstances.Any())
        {
            <div class="row mb-3">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <h6 class="mb-0">Service Events</h6>
                        </div>
                        <div class="card-body">
                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>Event Type</th>
                                        <th>Person</th>
                                        <th>Song</th>
                                        <th>Notes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < service.EventInstances.Count; i++)
                                    {
                                        var instance = service.EventInstances[i];
                                        <tr>
                                            <td>@instance.ServiceEvent?.Type</td>
                                            <td>
                                                <input type="text" class="form-control form-control-sm"
                                                       @bind="instance.PersonName"
                                                       placeholder="Person's name" />
                                            </td>
                                            <td>
                                                @if (instance.ServiceEvent?.Type == EventType.Song)
                                                {
                                                    <select class="form-select form-select-sm" @bind="instance.SongId" @key="instance">
                                                        <option value="">Select a song...</option>
                                                        @if (songs != null)
                                                        {
                                                            // Exclude songs that are already selected in other event lines for this service,
                                                            // but allow the current instance's selection to remain available in its own dropdown.
                                                            var filteredSongs = songs
                                                                .Where(s =>
                                                                    (service.IsSeasonal ? s.Seasonal : !s.Seasonal) &&
                                                                    !service.EventInstances.Any(ei =>
                                                                        ei != instance &&
                                                                        ei.SongId.HasValue &&
                                                                        ei.SongId.Value == s.Id));

                                                            // Order by last played (oldest first), with never-played songs at the end, then by name
                                                            filteredSongs = filteredSongs
                                                                .OrderBy(s => lastPlayedDates != null && lastPlayedDates.TryGetValue(s.SongName, out var dt) && dt.HasValue ? dt.Value : DateTime.MaxValue)
                                                                .ThenBy(s => s.SongName);

                                                            @foreach (var song in filteredSongs)
                                                            {
                                                                <option @key="song.Id" value="@song.Id">
                                                                    @FormatSongOption(song)
                                                                </option>
                                                            }
                                                        }
                                                    </select>
                                                }
                                            </td>
                                            <td>
                                                <input type="text" class="form-control form-control-sm"
                                                       @bind="instance.Notes"
                                                       placeholder="Additional notes" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-circle"></i> @(IsEdit ? "Update Service" : "Create Service")
            </button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">
                Cancel
            </button>
        </div>
    </form>
}

@code {
    [Parameter] public int Id { get; set; }

    private Service? service;
    private List<ServiceTemplate>? templates;
    private List<Song>? songs;
    private Dictionary<string, DateTime?>? lastPlayedDates;
    private bool loading = true;
    private string Title => IsEdit ? "Edit Service" : "Create New Service";
    private bool IsEdit => Id > 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        if (IsEdit)
        {
            service = await ServiceService.GetServiceByIdAsync(Id);
            if (service == null)
            {
                Navigation.NavigateTo("/services");
                return;
            }
        }
        else
        {
            service = new Service
            {
                ServiceDate = DateTime.Today,
                IsSeasonal = false
            };
        }
        loading = false;
    }

    private async Task LoadData()
    {
        templates = await TemplateService.GetAllTemplatesAsync();
        songs = await SongService.GetAllSongsAsync();
        lastPlayedDates = await SongService.GetLastPlayedDatesAsync();
    }

    private async Task SaveService()
    {
        if (IsEdit)
        {
            service = await ServiceService.UpdateServiceAsync(service!);
        }
        else
        {
            service = await ServiceService.CreateServiceAsync(service!);
        }

        Navigation.NavigateTo($"/services/view/{service.Id}");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/services");
    }

    private async Task OnTemplateChanged()
    {
        if (service.TemplateId > 0)
        {
            var template = await TemplateService.GetTemplateByIdAsync(service.TemplateId);
            if (template != null)
            {
                service.Template = template;

                // Auto-populate service name with template name + service date if name is empty
                if (string.IsNullOrWhiteSpace(service.Name))
                {
                    service.Name = $"{template.Name} - {service.ServiceDate:MMM dd, yyyy}";
                }

                service.EventInstances = template.Events.Select(evt => new ServiceEventInstance
                {
                    ServiceId = service.Id,
                    ServiceEventId = evt.Id,
                    ServiceEvent = evt,
                    PersonName = "",
                    SongId = null,
                    Notes = ""
                }).ToList();
            }
        }
        else
        {
            service.EventInstances.Clear();
        }
    }

    private void OnServiceDateChanged()
    {
        // Update service name when date changes if we have a template and the name follows the auto-generated pattern
        if (service.Template != null && !string.IsNullOrWhiteSpace(service.Template.Name))
        {
            // Check if the current name follows the pattern "Template Name - Date"
            var expectedPrefix = $"{service.Template.Name} - ";
            if (service.Name.StartsWith(expectedPrefix))
            {
                service.Name = $"{service.Template.Name} - {service.ServiceDate:MMM dd, yyyy}";
            }
        }
    }

    private string FormatSongOption(Song song)
    {
        return $"{song.SongName} - {song.Artist}";
    }
}